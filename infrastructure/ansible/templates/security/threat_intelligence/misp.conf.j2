server {
    listen 80;
    server_name {{ misp_fqdn }};
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name {{ misp_fqdn }};

    ssl_certificate /etc/nginx/ssl/{{ misp_fqdn }}/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/{{ misp_fqdn }}/privkey.pem;
    # Use Let's Encrypt or your own CA; for production, include real paths.

    root /var/www/MISP/app/webroot;
    index index.php;

    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_pass unix:/var/run/php/php{{ php_version }}-fpm.sock;
        fastcgi_read_timeout 300;
    }

    location ~ \.htaccess {
        deny all;
    }

    client_max_body_size 50M;
}