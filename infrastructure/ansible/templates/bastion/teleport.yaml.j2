version: v3
teleport:
  nodename: "{{ ansible_hostname }}"
  data_dir: /var/lib/teleport
  auth_token: "{{ teleport_auth_token }}"
  auth_servers:
    - "{{ groups['bastion_hosts'][0] }}:3025"
  proxy:
    enabled: true
    listen_addr: "0.0.0.0:443"
    https_keypairs:
      - key_file: /etc/teleport/privkey.pem
        cert_file: /etc/teleport/fullchain.pem
auth_service:
  enabled: true
  listen_addr: "0.0.0.0:3025"
  cluster_name: "{{ teleport_cluster_name }}"
ssh_service:
  enabled: true